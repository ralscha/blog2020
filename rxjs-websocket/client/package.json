{
  "name": "client",
  "version": "0.0.1",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "serve-dist": "ws --hostname localhost -d dist/client -p 1234 -o --log.format stats",
    "pbts": "pbjs -t static-module --es6 -w es6 ../server/src/main/protobuf/Calculator.proto -o src/app/protos/calculator.js && pbts --no-comments src/app/protos/calculator.js -o src/app/protos/calculator.d.ts",
    "format": "npx prettier --write ."
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "22.0.1",
    "@angular/common": "22.0.1",
    "@angular/compiler": "22.0.1",
    "@angular/core": "22.0.1",
    "@angular/forms": "22.0.1",
    "@angular/platform-browser": "22.0.1",
    "@angular/router": "22.0.1",
    "date-fns": "4.4.0",
    "echarts": "6.1.0",
    "ngx-echarts": "22.0.0",
    "protobufjs": "8.6.4",
    "resize-observer-polyfill": "1.5.1",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "zone.js": "0.16.2"
  },
  "devDependencies": {
    "@angular/build": "22.0.1",
    "@angular/cli": "22.0.1",
    "@angular/compiler-cli": "22.0.1",
    "local-web-server": "5.4.0",
    "prettier": "3.8.4",
    "protobufjs-cli": "2.5.5",
    "typescript": "6.0.3"
  }
}
